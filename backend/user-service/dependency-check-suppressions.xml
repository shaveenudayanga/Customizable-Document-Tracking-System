<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    
    <!-- 
    This file contains suppressions for OWASP Dependency Check.
    Add suppressions here for false positives or accepted risks.
    
    Example suppression:
    <suppress>
        <notes><![CDATA[
            This is a false positive. The vulnerability is not applicable to our usage.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.example/example\-lib@.*$</packageUrl>
        <cve>CVE-2021-12345</cve>
    </suppress>
    -->
    
    <!-- Suppress false positives for test dependencies -->
    <suppress>
        <notes><![CDATA[
            Test dependencies are not part of the runtime application.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/.*@.*$</packageUrl>
        <gav regex="true">^.*:.*:.*:test:.*$</gav>
    </suppress>
    
    <!-- Suppress Spring Boot DevTools vulnerabilities (dev-only dependency) -->
    <suppress>
        <notes><![CDATA[
            Spring Boot DevTools is only used in development and not in production.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/spring\-boot\-devtools@.*$</packageUrl>
    </suppress>
    
</suppressions>
