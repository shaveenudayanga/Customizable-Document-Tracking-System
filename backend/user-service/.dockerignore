# ================================
# Docker Ignore for User Service
# ================================

# Git and version control
.git
.gitignore
.gitattributes
.github/

# IDE/Editor files
.vscode/
.idea/
*.iml
*.iws
*.ipr
.settings/
.project
.classpath
.factorypath

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# Environment and secrets
.env
.env.*
*.secret
*.key
*.pem
*.p12
*.jks

# Build artifacts (keep compiled classes)
target/test-classes/
target/surefire-reports/
target/failsafe-reports/
target/generated-sources/
target/generated-test-sources/
target/maven-archiver/
target/maven-status/

# Documentation
README.md
*.md
docs/

# Test files
src/test/
**/test/**
**/*test*
**/*Test*

# Development tools
# .mvn/  # Needed for Maven wrapper
# mvnw   # Needed for Maven wrapper
# mvnw.cmd  # Needed for Maven wrapper
# pom.xml  # Needed for build
# Dockerfile  # Needed if not specified
docker-compose.yml
docker-compose.*.yml

# Kubernetes
k8s/
*.yaml
*.yml
!application.yml
!application-*.yml

# Logs
logs/
*.log

# Cache
.cache/
.npm/
node_modules/

# Backup files
*.bak
*.backup
*.old
*.orig
*.tmp

# Coverage and reports
coverage/
*.coverage

# Database files
*.db
*.mv.db
*.trace.db

# Scripts
scripts/
postman_collection.json
postman_environment*.json
