<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_ServiceOrchestration" targetNamespace="http://localhost:8083/api/workflow" exporter="Camunda Modeler" exporterVersion="5.36.1">
  <bpmn:process id="document_service_orchestration" name="Document Service Orchestration" isExecutable="true" camunda:historyTimeToLive="P30D">
    <bpmn:startEvent id="StartEvent_DocumentSubmitted" name="Document Submitted">
      <bpmn:outgoing>Flow_ToDocumentService</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_ToDocumentService" sourceRef="StartEvent_DocumentSubmitted" targetRef="Task_CreateDocument" />
    <bpmn:serviceTask id="Task_CreateDocument" name="Create Document" camunda:type="external" camunda:topic="document-service-create">
      <bpmn:incoming>Flow_ToDocumentService</bpmn:incoming>
      <bpmn:outgoing>Flow_ToWorkflowService</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_ToWorkflowService" sourceRef="Task_CreateDocument" targetRef="Task_StartWorkflow" />
    <bpmn:serviceTask id="Task_StartWorkflow" name="Start Approval Workflow" camunda:type="external" camunda:topic="workflow-service-start">
      <bpmn:incoming>Flow_ToWorkflowService</bpmn:incoming>
      <bpmn:outgoing>Flow_ToTrackingService</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_ToTrackingService" sourceRef="Task_StartWorkflow" targetRef="Task_RegisterQR" />
    <bpmn:serviceTask id="Task_RegisterQR" name="Register QR Code" camunda:type="external" camunda:topic="tracking-service-register">
      <bpmn:incoming>Flow_ToTrackingService</bpmn:incoming>
      <bpmn:outgoing>Flow_ToNotificationService</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_ToNotificationService" sourceRef="Task_RegisterQR" targetRef="Task_SendNotification" />
    <bpmn:serviceTask id="Task_SendNotification" name="Send Creation Notification" camunda:type="external" camunda:topic="notification-service-send">
      <bpmn:incoming>Flow_ToNotificationService</bpmn:incoming>
      <bpmn:outgoing>Flow_1njz4fs</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ApprovalLoop" default="Flow_ToUserApproval">
      <bpmn:incoming>Flow_NotifyApproval</bpmn:incoming>
      <bpmn:outgoing>Flow_ToUserApproval</bpmn:outgoing>
      <bpmn:outgoing>Flow_0atuhrg</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_UserApproval" name="Department Approval" camunda:candidateGroups="${currentDepartment}">
      <bpmn:incoming>Flow_0atuhrg</bpmn:incoming>
      <bpmn:incoming>Flow_1njz4fs</bpmn:incoming>
      <bpmn:outgoing>Flow_ApprovalDecision</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_ApprovalDecision" sourceRef="Task_UserApproval" targetRef="Gateway_ApprovalDecision" />
    <bpmn:exclusiveGateway id="Gateway_ApprovalDecision" default="Flow_Rejected">
      <bpmn:incoming>Flow_ApprovalDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_Approved" sourceRef="Gateway_ApprovalDecision" targetRef="Task_RecordApproval">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Rejected" sourceRef="Gateway_ApprovalDecision" targetRef="Task_RecordRejection" />
    <bpmn:serviceTask id="Task_RecordApproval" name="Record Approval Event" camunda:type="external" camunda:topic="tracking-service-event">
      <bpmn:incoming>Flow_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyApproval</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_NotifyApproval" sourceRef="Task_RecordApproval" targetRef="Gateway_ApprovalLoop" />
    <bpmn:serviceTask id="Task_NotifyApproval" name="Notify Approval" camunda:type="external" camunda:topic="notification-service-approval">
      <bpmn:incoming>Flow_ToUserApproval</bpmn:incoming>
      <bpmn:outgoing>Flow_06bx8qu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_RecordRejection" name="Record Rejection Event" camunda:type="external" camunda:topic="tracking-service-rejection">
      <bpmn:incoming>Flow_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyRejection</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_NotifyRejection" sourceRef="Task_RecordRejection" targetRef="Task_NotifyRejection" />
    <bpmn:serviceTask id="Task_NotifyRejection" name="Notify Rejection" camunda:type="external" camunda:topic="notification-service-rejection">
      <bpmn:incoming>Flow_NotifyRejection</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndRejected</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_ToEndRejected" sourceRef="Task_NotifyRejection" targetRef="End_DocumentRejected" />
    <bpmn:endEvent id="End_DocumentRejected" name="Document Rejected">
      <bpmn:incoming>Flow_ToEndRejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_FinalizeWorkflow" name="Finalize Workflow" camunda:type="external" camunda:topic="workflow-service-finalize">
      <bpmn:incoming>Flow_06bx8qu</bpmn:incoming>
      <bpmn:outgoing>Flow_ToFinalNotification</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_ToFinalNotification" sourceRef="Task_FinalizeWorkflow" targetRef="Task_SendFinalNotification" />
    <bpmn:serviceTask id="Task_SendFinalNotification" name="Send Completion Notification" camunda:type="external" camunda:topic="notification-service-complete">
      <bpmn:incoming>Flow_ToFinalNotification</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndApproved</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_ToEndApproved" sourceRef="Task_SendFinalNotification" targetRef="End_DocumentApproved" />
    <bpmn:endEvent id="End_DocumentApproved" name="Document Approved">
      <bpmn:incoming>Flow_ToEndApproved</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToUserApproval" sourceRef="Gateway_ApprovalLoop" targetRef="Task_NotifyApproval" />
    <bpmn:sequenceFlow id="Flow_0atuhrg" sourceRef="Gateway_ApprovalLoop" targetRef="Task_UserApproval">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${moreApprovalsRequired == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_06bx8qu" sourceRef="Task_NotifyApproval" targetRef="Task_FinalizeWorkflow" />
    <bpmn:sequenceFlow id="Flow_1njz4fs" sourceRef="Task_SendNotification" targetRef="Task_UserApproval" />
    <bpmn:textAnnotation id="TextAnnotation_1pfkxco">
      <bpmn:text>More Steps?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1hqqtbm" associationDirection="None" sourceRef="Gateway_ApprovalLoop" targetRef="TextAnnotation_1pfkxco" />
    <bpmn:textAnnotation id="TextAnnotation_0nrk3hp">
      <bpmn:text>Approved?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_016garb" associationDirection="None" sourceRef="Gateway_ApprovalDecision" targetRef="TextAnnotation_0nrk3hp" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_ServiceOrchestration">
    <bpmndi:BPMNPlane id="BPMNPlane_ServiceOrchestration" bpmnElement="document_service_orchestration">
      <bpmndi:BPMNShape id="StartEvent_DocumentSubmitted_di" bpmnElement="StartEvent_DocumentSubmitted">
        <dc:Bounds x="152" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="132" y="145" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreateDocument_di" bpmnElement="Task_CreateDocument">
        <dc:Bounds x="240" y="80" width="100" height="80" />
