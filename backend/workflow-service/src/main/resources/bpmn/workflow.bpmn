      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordApproval_di" bpmnElement="Task_RecordApproval">
        <dc:Bounds x="1110" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordRejection_di" bpmnElement="Task_RecordRejection">
        <dc:Bounds x="980" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyRejection_di" bpmnElement="Task_NotifyRejection">
        <dc:Bounds x="980" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_DocumentRejected_di" bpmnElement="End_DocumentRejected">
        <dc:Bounds x="1012" y="442" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1004" y="485" width="52" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FinalizeWorkflow_di" bpmnElement="Task_FinalizeWorkflow">
        <dc:Bounds x="540" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendFinalNotification_di" bpmnElement="Task_SendFinalNotification">
        <dc:Bounds x="390" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Association_1hqqtbm_di" bpmnElement="Association_1hqqtbm">
