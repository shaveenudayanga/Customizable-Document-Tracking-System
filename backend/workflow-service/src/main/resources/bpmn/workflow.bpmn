      <bpmndi:BPMNShape id="Task_StartWorkflow_di" bpmnElement="Task_StartWorkflow">
        <dc:Bounds x="390" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RegisterQR_di" bpmnElement="Task_RegisterQR">
        <dc:Bounds x="540" y="80" width="100" height="80" />
