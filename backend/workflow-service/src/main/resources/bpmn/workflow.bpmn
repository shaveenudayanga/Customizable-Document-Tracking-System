      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_DocumentApproved_di" bpmnElement="End_DocumentApproved">
        <dc:Bounds x="272" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="264" y="265" width="52" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ApprovalLoop_di" bpmnElement="Gateway_ApprovalLoop" isMarkerVisible="true">
