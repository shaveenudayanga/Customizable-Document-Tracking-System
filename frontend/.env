# Backend API Configuration
# For development, use proxy configuration in vite.config.js
# For production, set to actual backend URL
VITE_API_URL=/api

# API Configuration
VITE_API_TIMEOUT_MS=10000

# API Credentials
VITE_API_WITH_CREDENTIALS=true

# Development mode flag
VITE_DEV_MODE=true

# Backend Service Ports (for reference)
# user-service: 8081
# document-service: 8082
# workflow-service: 8083
# tracking-service: 8084


