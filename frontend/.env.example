# Vite environment variables (loaded at build time)
# Copy to .env (for local dev) or pass as build-arg in Docker builds.

# Backend API base URL
# For development with Vite proxy: /api
# For production: http://your-backend-url/api
VITE_API_URL=/api

# Optional tweakables
VITE_API_TIMEOUT_MS=15000
VITE_API_WITH_CREDENTIALS=true

# Backend Service Ports (for reference in development)
# user-service: 8081 (/api/auth/*)
# document-service: 8082 (/api/documents/*)
# workflow-service: 8083 (/api/workflow/*)
# tracking-service: 8084 (/api/tracking/*)
